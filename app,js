let database = [];
let selectedRows = []; // To track data added to the table

// 1. Load the database and populate the Building dropdown
fetch("database.json")
    .then(res => res.json())
    .then(data => {
        database = data;
        const select = document.getElementById("buildingSelect");
        
        database.forEach(item => {
            let option = document.createElement("option");
            option.value = item.building;
            option.text = item.building;
            select.appendChild(option);
        });
    });

// 2. Add selected building to the table
function addRow() {
    const buildingCode = document.getElementById("buildingSelect").value;
    const match = database.find(d => d.building === buildingCode);
    const table = document.getElementById("ecsTable");

    if (match) {
        const rowId = Date.now(); // Unique ID for tracking
        const row = table.insertRow();
        row.setAttribute("data-id", rowId);

        // Cell 1: Building & ECS Code
        row.insertCell(0).innerHTML = `<b>${match.building}</b> (${match.ecs})`;

        // Cell 2: Validation Dropdown
        row.insertCell(1).innerHTML = `
            <select class="row-validation">
                <option>1HAND_POS</option>
                <option>2PREP_ALMT</option>
                <option>3WELDING</option>
                <option>4PUNCH</option>
            </select>`;

        // Cell 3: Remove Button
        row.insertCell(2).innerHTML = `<button onclick="this.parentElement.parentElement.remove()">Delete</button>`;
        
        // Store technical data in an array or just read from DOM later
        selectedRows.push({ id: rowId, building: match.building, ecs: match.ecs });
    }
}

// 3. Collect all data from the table and export to Excel
function exportExcel() {
    const table = document.getElementById("ecsTable");
    const rows = table.querySelectorAll("tr");
    let exportData = [];

    // Skip the header row (index 0)
    for (let i = 1; i < rows.length; i++) {
        const buildingText = rows[i].cells[0].innerText;
        const validationValue = rows[i].cells[1].querySelector("select").value;
        
        // Extract building and ecs from the text "B101 (ECS001)"
        const building = buildingText.split(" (")[0];
        const ecs = buildingText.split("(")[1].replace(")", "");

        exportData.push({
            "Building": building,
            "ECS Code": ecs,
            "Validation": validationValue
        });
    }

    if(exportData.length === 0) return alert("Table is empty!");

    const newSheet = XLSX.utils.json_to_sheet(exportData);
    const newWorkbook = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(newWorkbook, newSheet, "ValidatedData");
    XLSX.writeFile(newWorkbook, "manual_validation_output.xlsx");
}
