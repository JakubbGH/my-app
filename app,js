let database = []

fetch("database.json")
.then(res => res.json())
.then(data => database = data)


function processFile(){

let file = document.getElementById("excelFile").files[0]

let reader = new FileReader()

reader.onload = function(e){

let data = new Uint8Array(e.target.result)

let workbook = XLSX.read(data,{type:"array"})

let sheet = workbook.Sheets[workbook.SheetNames[0]]

let json = XLSX.utils.sheet_to_json(sheet)

let validation = document.getElementById("validation").value


json.forEach(row => {

let match = database.find(d => d.building == row.Building)

if(match){

row["ECS Code"] = match.ecs

}

row["Validation"] = validation

})


let newSheet = XLSX.utils.json_to_sheet(json)

let newWorkbook = XLSX.utils.book_new()

XLSX.utils.book_append_sheet(newWorkbook,newSheet,"Validated")

XLSX.writeFile(newWorkbook,"validated_output.xlsx")

}

reader.readAsArrayBuffer(file)

}
